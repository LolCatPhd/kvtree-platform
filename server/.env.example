# KV Tree API — environment template
# Copy to .env and fill in. NEVER commit the real .env.

# --- Server ---
PORT=5000
# Public base URL of THIS api (used to build absolute upload/quote links).
PUBLIC_URL=http://localhost:5000

# --- PostgreSQL ---
# Railway provides these automatically when you link a Postgres plugin.
# Set the individual PG* vars OR a single DATABASE_URL.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=kvtree
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# PGSSLMODE=require   # set for managed DBs over a public proxy

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Seed an initial admin on first boot (optional but recommended):
ADMIN_EMAIL=admin@kvtree.co.za
ADMIN_PASSWORD=change-me

# --- Email (SMTP) — leave blank to log instead of send ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=KV Tree <no-reply@kvtree.co.za>
# Internal address that receives a copy of every new lead:
INTERNAL_NOTIFY_EMAIL=

# --- WhatsApp (Twilio) — leave blank to log instead of send ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Payments (PayFast) — leave blank to disable online payments ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
# Public URL of the FRONTEND (for PayFast return/cancel redirects):
SITE_URL=http://localhost:3000

# --- Google Calendar (service account) — leave blank to disable ---
# Share the target calendar with GOOGLE_SA_EMAIL ("Make changes to events").
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary
CALENDAR_TIMEZONE=Africa/Johannesburg

# --- File storage (S3-compatible) — leave blank to use local disk ---
# Photos and generated PDFs go here. Local disk is EPHEMERAL on Railway (wiped
# on every redeploy/restart), so configure one of the options below for prod.
# Set S3_BUCKET + S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY to switch S3 on.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For non-AWS providers, set the endpoint and path-style addressing:
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true
# Public base URL for object links (the bucket/CDN must be publicly readable so
# customers can open their photos and PDFs):
# S3_PUBLIC_URL=

# ---- Recipe A: Cloudflare R2 (free 10GB, no egress fees) ----
# 1. Cloudflare dashboard → R2 → Create bucket (e.g. "kvtree-uploads").
# 2. Bucket → Settings → enable Public access (r2.dev) OR attach a custom domain.
# 3. R2 → Manage API Tokens → create a token with Object Read & Write.
# 4. Set:
#   S3_BUCKET=kvtree-uploads
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID=<R2 access key id>
#   S3_SECRET_ACCESS_KEY=<R2 secret access key>
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_FORCE_PATH_STYLE=true
#   S3_PUBLIC_URL=https://pub-<HASH>.r2.dev        # the bucket's public r2.dev URL
#
# ---- Recipe B: Supabase Storage (free 1GB, no card needed) ----
# 1. Supabase → Storage → New bucket "kvtree-uploads" → mark it Public.
# 2. Storage → Settings → S3 connection: copy endpoint, region, access keys.
# 3. Set:
#   S3_BUCKET=kvtree-uploads
#   S3_REGION=<region from dashboard, e.g. eu-west-1>
#   S3_ACCESS_KEY_ID=<supabase access key id>
#   S3_SECRET_ACCESS_KEY=<supabase secret>
#   S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
#   S3_FORCE_PATH_STYLE=true
#   S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/kvtree-uploads

# --- Geocoding / Maps ---
# GEOCODER=nominatim (default, free) or google
# GOOGLE_MAPS_API_KEY=
# KV Tree base location (Kempton Park) for distance calculations:
BASE_LAT=-26.0941
BASE_LNG=28.2336
