# KV Tree API — environment template
# Copy to .env and fill in. NEVER commit the real .env.

# Server
PORT=5000

# PostgreSQL connection.
# Railway provides these automatically when you link a Postgres plugin.
# You can either set the individual PG* vars OR a single DATABASE_URL.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=kvtree

# Alternatively, a full connection string (takes precedence if set):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "require" when connecting to a managed DB over a public proxy
# (e.g. Railway's public endpoint). Leave unset for local/internal.
# PGSSLMODE=require
